# Study-and-Learn Environment Configuration
# Copy this file to `.env` and fill in your actual values.
# Never commit secrets or API keys to version control.

# ── Flask Core ──────────────────────────────────────────────────────────────
# Secret key for session signing and CSRF protection.
# Generate a strong random string for production.
SECRET_KEY=change-me-in-production

# ── Database ────────────────────────────────────────────────────────────────
# SQLAlchemy database URI — PostgreSQL ONLY.
# Format: postgresql+psycopg2://user:password@host:port/dbname
# The app will refuse to start if this does not begin with `postgresql`.
DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/study_and_learn

# ── AI / Ollama Configuration ───────────────────────────────────────────────
# Set to `true` to return deterministic mock responses (CI/testing mode).
AI_MOCK=false

# Backend selector: `local` or `cloud`.
# If `cloud`, ensure OLLAMA_CLOUD_API_KEY and OLLAMA_CLOUD_BASE_URL are set.
AI_BACKEND=local

# Local Ollama settings
OLLAMA_MODEL=qwen3:0.6b
OLLAMA_EMBEDDING_MODEL=qwen3-embedding:0.6b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT=180

# Ollama Cloud settings (only needed when AI_BACKEND=cloud)
OLLAMA_CLOUD_API_KEY=your-ollama-cloud-api-key-here
OLLAMA_CLOUD_BASE_URL=https://ollama.com

# ── CI / Testing ───────────────────────────────────────────────────────────
# Set to `true` in GitHub Actions to force ephemeral (in-memory) ChromaDB and mock AI.
CI=false

# ── Session Storage ─────────────────────────────────────────────────────────
# Optional override for the Flask-Session filesystem cache directory.
# Defaults to data/flask_session if not set.
FLASK_SESSION_DIR=data/flask_session

# ── OCR / Vision Models ─────────────────────────────────────────────────────
# Local OCR model (no cloud variant available — must be pulled locally)
OLLAMA_OCR_MODEL=glm-ocr

# Vision-language model for figure descriptions (cloud only — 397B MoE too large for local)
# Migrated from qwen3-vl:235b-cloud (deprecated). Qwen3.5 family: same vendor, same
# input modality (Text+Image), 256K context, Medium cloud cost tier.
OLLAMA_VISION_MODEL=qwen3.5:397b-cloud

# Maximum seconds per page for OCR processing
OCR_TIMEOUT_PER_PAGE=120

# Maximum image dimension before resizing (preserves aspect ratio)
OCR_MAX_IMAGE_DIMENSION=2048

# Maximum file size in bytes to send for OCR processing. Images larger than
# this are silently skipped with a warning. Prevents OOM on very large scans.
OCR_MAX_FILE_BYTES=52428800

# Set to "true" to run all three OCR modes (text + table + figure) per page.
# Defaults to text-only OCR for speed. Only enable for image-heavy PDFs.
OCR_FULL=false

# Set to "true" to call Qwen3.5 cloud for per-page figure descriptions.
# Adds ~15-30 seconds per page. Disabled by default.
OCR_FIGURE_DESCRIPTION=false

# Poppler binary path (Windows only). Set this if you prefer not to modify
# your system PATH. Leave commented on macOS/Linux — pdftoppm is auto-detected.
#POPPLER_PATH=C:\Program Files\poppler\Library\bin